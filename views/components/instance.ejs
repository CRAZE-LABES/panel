<div class="bg-gray-800 rounded-lg shadow-sm mx-4 sm:mx-6 mt-6 mb-6">
    <div class="relative">
        <nav class="flex overflow-x-auto pb-1 px-1 scrollbar-hide">
            <ul role="list" class="flex flex-nowrap text-sm font-medium text-white">
                <li class="shrink-0 relative">
                    <a href="/instance/<%= req.params.id %>" class="nav-link2 px-4 py-3 hover:text-white transition-colors duration-150 flex items-center text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-4 h-4 mr-2"><rect width="256" height="256" fill="none"/><path d="M216,40H40A16,16,0,0[...]"/>
                        Console
                    </a>
                </li>
                <li class="shrink-0 relative">
                    <a href="/instance/<%= req.params.id %>/files" class="nav-link2 px-4 py-3 hover:text-white transition-colors duration-150 flex items-center text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-4 h-4 mr-2"><rect width="256" height="256" fill="none"/><path d="M224,64H154.67L126.9[...]"/>
                        Files
                    </a>
                </li>
                <li class="shrink-0 relative">
                    <a href="/instance/<%= req.params.id %>/users" class="nav-link2 px-4 py-3 hover:text-white transition-colors duration-150 flex items-center text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-4 h-4 mr-2"><rect width="256" height="256" fill="none"/><path d="M164.47,195.63a8,8,0[...]"/>
                        Users
                    </a>
                </li>
                <li class="shrink-0 relative">
                    <a href="/instance/<%= req.params.id %>/network" class="nav-link2 px-4 py-3 hover:text-white transition-colors duration-150 flex items-center text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-4 h-4 mr-2"><rect width="256" height="256" fill="none"/><path d="M240,120a8,8,0,0,1-8[...]"/>
                        Network
                    </a>
                </li>
                <li class="shrink-0 relative">
                    <a href="/instance/<%= req.params.id %>/archives" class="nav-link2 px-4 py-3 hover:text-white transition-colors duration-150 flex items-center text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-4 h-4 mr-2"><rect width="256" height="256" fill="none"/><path d="M223.16,68.42l-16-32[...]"/>
                        Backups
                    </a>
                </li>
                <li class="shrink-0 relative">
                    <a href="/instance/<%= req.params.id %>/plugins" class="nav-link2 px-4 py-3 hover:text-white transition-colors duration-150 flex items-center text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-4 h-4 mr-2"><rect width="256" height="256" fill="none"/><path d="M208,32H184V24a8,8,0[...]"/>
                        Plugins
                    </a>
                </li>
                <li class="shrink-0 relative">
                    <a href="/instance/<%= req.params.id %>/ftp" class="nav-link2 px-4 py-3 hover:text-white transition-colors duration-150 flex items-center text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-4 h-4 mr-2"><rect width="256" height="256" fill="none"/><path d="M74.34,77.66a8,8,0,0[...]"/>
                        FTP
                    </a>
                </li>
                <li class="shrink-0 relative">
                    <a href="/instance/<%= req.params.id %>/settings" class="nav-link2 px-4 py-3 hover:text-white transition-colors duration-150 flex items-center text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-4 h-4 mr-2"><rect width="256" height="256" fill="none"/><path d="M237.94,107.21a8,8,0[...]"/>
                        Settings
                    </a>
                </li>
                <li class="shrink-0 relative">
                    <a href="/instance/<%= req.params.id %>/startup" class="nav-link2 px-4 py-3 hover:text-white transition-colors duration-150 flex items-center text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-4 h-4 mr-2"><rect width="256" height="256" fill="none"/><path d="M32,80a8,8,0,0,1,8-8[...]"/>
                        Startup
                    </a>
                </li>

                <% if (addons && addons.plugins) { %>
                    <% addons.plugins.forEach(plugin => { %>
                        <% if (plugin.instancesidebar) { %>
                            <% Object.entries(plugin.instancesidebar).forEach(([key, value]) => { %>
                                <li class="shrink-0 relative">
                                    <a href="<%= (value.url).replace('%id%', req.params.id) %>" class="nav-link2 px-4 py-3 hover:text-white transition-colors duration-150 flex items-center text-white">
                                        <i class="w-4 h-4 mr-2 <%= value.icon %>"></i>
                                        <%= key %>
                                    </a>
                                </li>
                            <% }); %>
                        <% } %>
                    <% }); %>
                <% } %>
            </ul>
        </nav>
    </div>
</div>

<style>
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    .nav-link2,
    .nav-link2 * {
        color: #fff !important;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const navLinks = document.querySelectorAll('.nav-link2');

        // Set all links to white (active/inactive)
        navLinks.forEach(link => {
            link.classList.add('text-white');
            link.classList.remove('text-gray-400', 'text-cyan-500', 'text-gray-200');
        });

        // Optional: Make sure hover color is also white (handled by class)
        // No active link color switching needed since all are white
    });
</script>
